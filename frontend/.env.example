# Copy this file to .env and fill in your values

# Supabase credentials (same project as cloak-hosted)
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: point at a deployed cloak-hosted instance instead of localhost:3000
# VITE_API_BASE=https://cloak-hosted.vercel.app/api
